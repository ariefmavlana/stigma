# ═══════════════════════════════════════════════════════════
# STIgma — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (PostgreSQL 17) ─────────────────────────────────
DB_NAME=stigma
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── AI — NVIDIA NIM (Nemotron) ───────────────────────────────
# Get your key at: https://integrate.api.nvidia.com
# !! Never commit this value to version control !!
NVIDIA_API_KEY=nvapi-your-key-here

# Model to use (default shown below)
CREWAI_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# ── CrewAI Tools ─────────────────────────────────────────────
# For SerperDevTool (web search) — get free key at serper.dev
SERPER_API_KEY=your-serper-api-key
